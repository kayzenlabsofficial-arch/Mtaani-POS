{
  "name": "smart-pos",
  "private": true,
  "version": "0.0.0",
  "description": "Offline-first desktop POS for local retail businesses.",
  "author": "Smart POS",
  "type": "module",
  "main": "electron/main.cjs",
  "desktop": {
    "defaultApiBaseUrl": "https://smartpos.pages.dev"
  },
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "desktop:dev": "node scripts/desktop-dev.mjs",
    "desktop:build": "vite build",
    "desktop:start": "npm run desktop:build && electron .",
    "desktop:exe": "node scripts/build-desktop-exe.mjs",
    "mobile:sync": "node scripts/mobile-sync.mjs",
    "mobile:android": "npm run mobile:sync && cap open android",
    "mobile:apk": "node scripts/build-mobile-apk.mjs",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:integrity": "vitest run src/utils/posMoney.test.ts src/utils/cashDrawer.test.ts src/utils/salesInvoiceIntegrity.test.ts src/utils/inventoryIntegrity.test.ts src/utils/expenseIntegrity.test.ts src/utils/profitLoss.test.ts src/utils/reportAnalytics.test.ts functions/api/inventoryIntegrity.test.ts functions/api/expenses/expenseOps.test.ts functions/api/data/genericDataGuard.test.ts functions/api/sales/refundOps.test.ts functions/api/close/reportMath.test.ts functions/api/dashboard/metrics.test.ts functions/api/salesSecurity.test.ts functions/api/sales/invoiceAndUndo.test.ts functions/api/sales/refundBalanceFix.test.ts",
    "audit:money": "node scripts/money-integrity-audit.mjs",
    "wrangler:dev": "wrangler pages dev --port=8788",
    "wrangler:deploy": "wrangler pages deploy dist",
    "d1:setup": "wrangler d1 execute smart_pos_db --remote --file=schema.sql",
    "d1:local": "wrangler d1 execute smart_pos_db --local --file=schema.sql",
    "d1:hard-reset:local": "wrangler d1 execute smart_pos_db --local --file=schema.hard-reset.sql && wrangler d1 execute smart_pos_db --local --file=schema.sql",
    "d1:hard-reset:remote": "wrangler d1 execute smart_pos_db --remote --file=schema.hard-reset.sql && wrangler d1 execute smart_pos_db --remote --file=schema.sql",
    "db:setup": "node scripts/db-setup.js",
    "db:setup:local": "node scripts/db-setup.js --local",
    "db:setup:remote": "node scripts/db-setup.js --remote"
  },
  "dependencies": {
    "@capacitor-community/sqlite": "^8.1.0",
    "@capacitor/android": "^8.3.4",
    "@capacitor/core": "^8.3.4",
    "dexie": "^4.4.2",
    "dexie-react-hooks": "^4.4.0",
    "html2canvas": "^1.4.1",
    "html5-qrcode": "^2.3.8",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.546.0",
    "pdfjs-dist": "^5.7.284",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.8.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.4",
    "@cloudflare/workers-types": "^4.20260421.1",
    "@tailwindcss/vite": "^4.1.14",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.4",
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1",
    "javascript-obfuscator": "^5.4.2",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.7",
    "wrangler": "^4.90.0"
  },
  "build": {
    "appId": "com.smart.pos.desktop",
    "productName": "Smart POS",
    "artifactName": "${productName}-${version}-${arch}.${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "asar": true,
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  }
}
