# Server-side API secret used by Pages Functions.
API_SECRET="replace-with-your-pos-api-secret"

# Optional local fallback for the POS AI endpoint when a Workers AI binding is not available.
# Do not expose this token in browser code.
CLOUDFLARE_ACCOUNT_ID="replace-with-your-cloudflare-account-id"
CLOUDFLARE_AI_API_TOKEN="replace-with-your-cloudflare-ai-token"
CLOUDFLARE_AI_MODEL="@cf/meta/llama-3.1-8b-instruct"

# Software billing STK Push credentials. Use sandbox values for testing, production values when live.
MPESA_CREDENTIAL_ENCRYPTION_KEY="replace-with-long-random-secret-used-only-by-pages-functions"
BILLING_MPESA_CONSUMER_KEY="replace-with-daraja-consumer-key"
BILLING_MPESA_CONSUMER_SECRET="replace-with-daraja-consumer-secret"
BILLING_MPESA_SHORTCODE="174379"
BILLING_MPESA_PASSKEY="replace-with-daraja-passkey"
BILLING_MPESA_ENV="sandbox"
BILLING_MPESA_CALLBACK_SECRET="replace-with-random-callback-secret"

# WhatsApp Cloud API webhook and replies.
WHATSAPP_ACCESS_TOKEN="replace-with-meta-system-user-or-test-token"
WHATSAPP_PHONE_NUMBER_ID="replace-with-whatsapp-phone-number-id"
WHATSAPP_BUSINESS_ACCOUNT_ID="replace-with-whatsapp-business-account-id"
WHATSAPP_VERIFY_TOKEN="replace-with-random-webhook-verify-token"
WHATSAPP_APP_SECRET="optional-meta-app-secret-for-webhook-signature-checks"
WHATSAPP_GRAPH_API_VERSION="v25.0"
