# Server-side API secret used by Pages Functions.
API_SECRET="replace-with-your-pos-api-secret"

# Optional local fallback for the POS AI endpoint when a Workers AI binding is not available.
# Do not expose this token in browser code.
CLOUDFLARE_ACCOUNT_ID="replace-with-your-cloudflare-account-id"
CLOUDFLARE_AI_API_TOKEN="replace-with-your-cloudflare-ai-token"
CLOUDFLARE_AI_MODEL="@cf/meta/llama-3.1-8b-instruct"
