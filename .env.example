# Server-side API secret used by Pages Functions.
API_SECRET="replace-with-your-pos-api-secret"

# Temporary password used when super admin creates a business or resets staff.
BUSINESS_BOOTSTRAP_PASSWORD="replace-with-temporary-password-shared-outside-the-app"

# M-Pesa credential encryption key for safely storing business payment settings.
MPESA_CREDENTIAL_ENCRYPTION_KEY="replace-with-long-random-secret-used-only-by-pages-functions"

# Random callback path segment used by Safaricom STK callbacks.
MPESA_CALLBACK_SECRET="replace-with-long-random-callback-secret"

# Platform billing M-Pesa account. This receives Smart POS subscription payments.
BILLING_MPESA_ENV="sandbox"
BILLING_MPESA_CONSUMER_KEY="replace-with-platform-consumer-key"
BILLING_MPESA_CONSUMER_SECRET="replace-with-platform-consumer-secret"
BILLING_MPESA_SHORTCODE="replace-with-platform-shortcode"
BILLING_MPESA_PASSKEY="replace-with-platform-passkey"
BILLING_MPESA_ACCOUNT_TYPE="paybill"
BILLING_MPESA_STORE_NUMBER=""
BILLING_MPESA_CALLBACK_SECRET="replace-with-platform-billing-callback-secret"

# Platform billing PesaPal account. PesaPal checkout can collect M-Pesa and settle to PesaPal.
BILLING_PESAPAL_ENV="sandbox"
BILLING_PESAPAL_CONSUMER_KEY="replace-with-pesapal-consumer-key"
BILLING_PESAPAL_CONSUMER_SECRET="replace-with-pesapal-consumer-secret"
BILLING_PESAPAL_IPN_SECRET="replace-with-long-random-pesapal-ipn-secret"
BILLING_PESAPAL_IPN_ID=""
BILLING_PESAPAL_CURRENCY="KES"
